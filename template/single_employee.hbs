<link rel="stylesheet" href="/public/style.css">

<h1>Employee Details</h1>
Name: {{employeeDetails.name}}<br>
Phone: {{employeeDetails.phone}}<br>
<a href="/edit/{{employeeDetails._id}}">Edit Details</a>

<h2>Shifts</h2>
<table>
<thead>
    <tr><th>Date</th><th>Start Time</th><th>End Time</th></tr>
</thead>
<tbody>
    {{#each shifts}}
    <tr>
        <td>{{date}}</td>
        {{#if startEarly}}
            <td class="early-time">{{startTime}}</td>
        {{else}}
            <td>{{startTime}}</td>
        {{/if}}
        <td>{{endTime}}</td>
    </tr>
    {{/each}}
</tbody>
</table>

<h2>Employee Documents</h2>

<form method="POST" action="/upload-document/{{employeeDetails._id}}" enctype="multipart/form-data">
    <input type="file" name="employeeDocument" accept=".pdf,application/pdf">
    <input type="submit" value="Upload PDF">
</form>

<p>Rules: PDF only, max 2MB, max 5 documents.</p>

<ul>
    {{#each documents}}
        <li>
            {{originalName}} -
            <a href="/document/{{../employeeDetails._id}}/{{documentId}}">Download</a>
        </li>
    {{/each}}
</ul>